body {
    background-color: white;
    color: black;
    font-family: sans-serif;
    padding: 10px;
    display: grid;

}

h1 { 
    color: red;
    font-size: 25px;
    text-align: center;
}
h2 {
    margin-left: 10px;
    color: darkred;
    font-size: 21px;
}
h3 {
    color: lightcoral;
    font-size: 19px;
}

p {
    font-weight: normal;

}

li {
    font-weight: bold;
    font-size: 17px;
    list-style-type: circle;
}

#navigation ul {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    justify-items: center;
}

#navigation li {
    font-size: 16px;
    font-weight: normal;
    list-style-type: square;
}

img {
    max-width: 100%;
    min-width: 320px;
    height: auto;
    padding: 20px;
}

#biografi {
    display: grid;
    align-items: start;
    grid-template-columns: 1fr 4fr;
}

#meriter {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
}

#kontaktinformation p {
    margin-left: 30px;
}

@media (max-width: 900px) {
    #navigation ul {
        display: flex;
        flex-direction: column;
    }
    #meriter {
        display: grid;
        grid-template-columns: 1fr;
    }
    #biografi {
        display: flex;
        flex-direction: column;
        align-items: center;
    }
}